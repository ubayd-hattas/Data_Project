ase tracking-wider text-slate-400","children":"Key statistics in this story"}],["$","div",null,{"className":"grid grid-cols-1 gap-3 sm:grid-cols-2","children":[["$","div","matric-pass-rate",{"className":"card p-4","children":[["$","p",null,{"className":"text-xs text-slate-500 dark:text-slate-400","children":"National Matric Pass Rate"}],["$","p",null,{"className":"mt-1 font-mono text-2xl font-medium text-slate-900 dark:text-white","children":"87.3%"}],["$","p",null,{"className":"mt-0.5 text-xs text-slate-400","children":["from 2023"," · ","DBE"]}]]}],["$","div","education-literacy",{"className":"card p-4","children":[["$","p",null,{"className":"text-xs text-slate-500 dark:text-slate-400","children":"Adult Literacy Rate (20+)"}],["$","p",null,{"className":"mt-1 font-mono text-2xl font-medium text-slate-900 dark:text-white","children":"87.0%"}],["$","p",null,{"className":"mt-0.5 text-xs text-slate-400","children":["since Census 2011"," · ","Stats SA"]}]]}],["$","div","higher-education-enrolment",{"className":"card p-4","children":[["$","p",null,{"className":"text-xs text-slate-500 dark:text-slate-400","children":"Higher Education Enrolment"}],["$","p",null,{"className":"mt-1 font-mono text-2xl font-medium text-slate-900 dark:text-white","children":"1.07M"}],["$","p",null,{"className":"mt-0.5 text-xs text-slate-400","children":["from 2022"," · ","DHET"]}]]}]]}]]}],["$","article",null,{"className":"prose-story","children":[["$","section","the-record",{"id":"the-record","className":"mb-10 scroll-mt-24","children":[["$","h2",null,{"className":"heading-display mb-4 text-xl font-semibold text-slate-900 dark:text-white","children":"A record worth celebrating — carefully"}],[["$","p","0",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"The 2024 National Senior Certificate pass rate of 87.3% is the highest since the current examination system was introduced in 2008. More than one million candidates wrote the exams, and a record 47.8% achieved a bachelor's degree pass — meaning they qualified for university entrance."}],["$","p","1",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"That is genuine progress. The sustained upward trend since 2015, with the exception of the COVID-disrupted 2020 cohort, reflects real improvements in teaching quality, curriculum support, and school management in many parts of the country."}]],["$","blockquote",null,{"className":"my-6 border-l-4 border-brand-400 pl-5","children":["$","p",null,{"className":"text-lg font-medium italic leading-relaxed text-slate-700 dark:text-slate-200","children":["\"","A record 87.3% pass rate — but what counts as a \"pass\" matters enormously.","\""]}]}],[["$","div",null,{"className":"my-6 rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6","children":[["$","div",null,{"className":"flex-shrink-0","children":[["$","p",null,{"className":"font-mono text-4xl font-medium tabular-nums text-slate-900 dark:text-white","children":"87.3%"}],["$","div",null,{"className":"mt-1 flex items-center gap-1.5","children":[["$","span",null,{"className":"flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium bg-brand-50 text-brand-700 dark:bg-brand-950/40 dark:text-brand-300","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":11,"height":11,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-trending-up","children":[["$","polyline","126l90",{"points":"22 7 13.5 15.5 8.5 10.5 2 17"}],["$","polyline","kwv8wd",{"points":"16 7 22 7 22 13"}],"$undefined"]}],"4.4","pp"]}],["$","span",null,{"className":"text-xs text-slate-400","children":"from 2023"}]]}]]}],["$","div",null,{"className":"hidden h-12 w-px bg-slate-100 dark:bg-slate-800 sm:block"}],["$","div",null,{"className":"flex-1 min-w-0","children":[["$","p",null,{"className":"text-sm font-semibold text-slate-900 dark:text-white","children":"National Matric Pass Rate"}],["$","p",null,{"className":"mt-1 text-sm leading-relaxed text-slate-500 dark:text-slate-400 line-clamp-2","children":"The national senior certificate (matric) pass rate for the 2024 academic year, the highest on record. Bachelor's degree passes (qualifying for university entrance) were achieved by 47.8% of candidates. 1,044,415 candidates wrote the examinations."}],["$","p",null,{"className":"mt-2 text-xs text-slate-400","children":["DBE"," · Updated ","15 January 2025"]}]]}]]}]]]}],["$","section","what-counts",{"id":"what-counts","className":"mb-10 scroll-mt-24","children":[["$","h2",null,{"className":"heading-display mb-4 text-xl font-semibold text-slate-900 dark:text-white","children":"What \"passing\" actually means"}],[["$","p","0",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"The National Senior Certificate requires a minimum of 30% in three subjects and 40% in three others. This is a relatively low bar. Critics have long argued that the matric pass rate gives an overly optimistic picture of educational achievement."}],["$","p","1",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"International assessments tell a more sobering story. South Africa consistently performs poorly in PIRLS (reading literacy) and TIMSS (mathematics and science) assessments. In the 2021 PIRLS study, 81% of South African Grade 4 learners could not read for meaning in any language — the worst result among all 57 participating countries."}],["$","p","2",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"The matric pass rate and actual literacy and numeracy skills are not the same thing."}]],["$","blockquote",null,{"className":"my-6 border-l-4 border-brand-400 pl-5","children":["$","p",null,{"className":"text-lg font-medium italic leading-relaxed text-slate-700 dark:text-slate-200","children":["\"","In 2021, 81% of SA Grade 4 learners could not read for meaning — the worst result globally.","\""]}]}],[]]}],["$","section","inequality",{"id":"inequality","className":"mb-10 scroll-mt-24","children":[["$","h2",null,{"className":"heading-display mb-4 text-xl font-semibold text-slate-900 dark:text-white","children":"Provincial and school-type disparities"}],[["$","p","0",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"The Western Cape (89.1%) and Free State (88.4%) consistently lead provincial pass rates. The Eastern Cape (79.8%) and KwaZulu-Natal (81.4%) lag behind."}],["$","p","1",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"The gap between fee-paying independent schools and no-fee public schools is stark. Independent schools achieve pass rates above 98% with high bachelor's pass rates. Many quintile 1 and 2 schools (the poorest) struggle to achieve 70%."}],["$","p","2",{"className":"mb-4 text-base leading-relaxed text-slate-700 dark:text-slate-300","children":"These disparities reflect decades of unequal investment in school infrastructure, teacher quality, and learning materials. Closing them requires sustained, targeted investment — not just in examinations, but in the foundation phases of schooling."}]],"$undefined",[["$","div",null,{"className":"my-6 rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6","children":[["$","div",null,{"className":"flex-shrink-0","children":[["$","p",null,{"className":"font-mono text-4xl font-medium tabular-nums text-slate-900 dark:text-white","children":"87.0%"}],["$","div",null,{"className":"mt-1 flex items-center gap-1.5","children":[["$","span",null,{"className":"flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium bg-brand-50 text-brand-700 dark:bg-brand-