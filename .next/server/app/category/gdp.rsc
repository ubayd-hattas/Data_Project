1b:{"id":"gdp-annual-growth","categoryId":"gdp","title":"GDP Annual Growth Rate","value":"1.1%","rawValue":1.1,"unit":"%","change":0.6,"changeLabel":"from 2024 (0.5%)","trend":"up","description":"South Africa's real GDP grew 1.1% for the full year 2025, the strongest annual rate since 2022. Growth was broad-based despite ongoing headwinds from high borrowing costs and slow global demand. Manufacturing registered its second year of negative growth; construction posted its ninth straight year of decline.","source":"$1c","lastUpdated":"2026-03-10","series":"$1d"}
