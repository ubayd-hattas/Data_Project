6:{"id":"unemployment-national","categoryId":"unemployment","title":"National Unemployment Rate","value":"31.4%","rawValue":31.4,"unit":"%","change":-0.5,"changeLabel":"from Q3 2025 (31.9%)","trend":"down","description":"South Africa's official unemployment rate fell to 31.4% in Q4 2025 — the lowest since Q2 2022 — as 44,000 more people found work. The number of employed persons rose to 17.1 million. The expanded unemployment rate (including discouraged work-seekers) stands at 40.7%.","source":"$7","lastUpdated":"2026-02-17","series":"$8"}
